# ── BACKEND (Node.js / Vercel Serverless) ──────────────────────────────────────

PORT=3000

# Token que inventas tú y registras en el panel de Meta al configurar el Webhook
WHATSAPP_VERIFY_TOKEN=fabriloko123

# Supabase Service Role Key (NO la anon key) — para saltar RLS desde el backend
# Panel de Supabase → Project Settings → API → service_role
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ── FRONTEND (Vite / React) ────────────────────────────────────────────────────

# Supabase Anon/Publishable Key — para el cliente React (auth, queries públicas)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
