PORT=3000

# Token que inventas tú y registras en el panel de Meta al configurar el Webhook
WHATSAPP_VERIFY_TOKEN=tu_token_secreto_aqui

# Panel de Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Usar Service Role Key (no anon key) para saltar el RLS desde el backend
# Se encuentra en: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...
